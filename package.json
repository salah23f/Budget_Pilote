    "ingest:bts-db1b": "npx tsx scripts/ingest/bts-db1b.ts",
    "ingest:bts-t100": "npx tsx scripts/ingest/bts-t100.ts",
    "ingest:kaggle": "npx tsx scripts/ingest/kaggle.ts",
    "ingest:expedia": "npx tsx scripts/ingest/expedia-icdm.ts",
    "ingest:huggingface": "npx tsx scripts/ingest/huggingface.ts",
    "ingest:fx-rates": "npx tsx scripts/ingest/fx-rates.ts",
    "ingest:quality": "npx tsx scripts/ingest/quality-gate.ts",
    "ingest:all": "npm run ingest:huggingface && npm run ingest:kaggle && npm run ingest:quality",
    "train:split": "python3 scripts/train/01-split.py",
    "train:features": "python3 scripts/train/02-features.py",
    "train:gp": "python3 scripts/train/03-fit-gp.py",
    "train:hmm": "python3 scripts/train/04-fit-hmm.py",
    "train:qrf": "python3 scripts/train/05-fit-qrf.py",
    "train:lstm": "python3 scripts/train/06-train-lstm.py",
    "train:vae": "python3 scripts/train/09-train-vae.py",
    "train:ensemble": "python3 scripts/train/12-fit-ensemble.py",
    "train:validate": "python3 scripts/train/13-validate.py",
    "train:audit": "python3 scripts/train/audit-leakage.py",
    "train:all": "npm run train:split && npm run train:features && npm run train:audit && npm run train:gp && npm run train:hmm && npm run train:qrf && npm run train:lstm && npm run train:vae && npm run train:ensemble && npm run train:validate",
    "train:smoke": "npm run train:split && npm run train:features && npm run train:qrf && npm run train:validate"
  },
  "dependencies": {
    "@privy-io/react-auth": "^2.25.0",
