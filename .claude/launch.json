{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "budgetpilot-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "docs-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "docs", "-l", "4321", "--no-clipboard"],
      "port": 4321,
      "autoPort": true
    }
  ]
}
