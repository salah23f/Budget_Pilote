# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# RapidAPI — single key for all 6 flight APIs
# Sky Scrapper (PAID PRO): sky-scrapper.p.rapidapi.com
# Air Scraper (free): air-scraper.p.rapidapi.com
# Kiwi.com (free): kiwi-com-cheap-flights.p.rapidapi.com
# Booking COM (free): booking-com15.p.rapidapi.com
# Google Flights2 (free): google-flights2.p.rapidapi.com
# WeatherAPI (free, 1M/mo): weatherapi-com.p.rapidapi.com
RAPIDAPI_KEY=
RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com

# Amadeus (backup flight provider, FREE 2000 calls/month)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# Scraper security (generate: openssl rand -hex 32)
SCRAPER_SECRET=

# V7 Algorithm version: v1 (default) | v7 | shadow
FLYEAS_ALGO_VERSION=shadow

# Anthropic Claude (chatbot)
ANTHROPIC_API_KEY=

# Resend (email alerts)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@faregenie.vercel.app

# Stripe (payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
