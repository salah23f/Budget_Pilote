# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# RapidAPI - Sky Scrapper (Primary: hotels + some flights)
# Get one at: https://rapidapi.com/apiheya/api/sky-scrapper
RAPIDAPI_KEY=
RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com

# Amadeus Self-Service API (Backup flight provider, FREE 2000 calls/month)
# Get free credentials: https://developers.amadeus.com/self-service
# Used automatically when Sky-Scrapper can't serve a route.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# Anthropic Claude (optional: powers the intelligent chatbot)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Resend (email alerts)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@faregenie.vercel.app

# Stripe (payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
